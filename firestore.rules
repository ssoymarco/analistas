rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Match data (server-written, anyone can read) ────────────────────
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;  // Only admin SDK (Cloud Functions) writes
    }

    match /matchDetails/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    match /standings/{seasonId} {
      allow read: if true;
      allow write: if false;
    }

    match /topscorers/{seasonId} {
      allow read: if true;
      allow write: if false;
    }

    // ── User profiles ───────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Username reservation (read: anyone, write: authenticated) ───────
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Server metadata (no client access) ──────────────────────────────
    match /_meta/{docId} {
      allow read, write: if false;
    }
  }
}
