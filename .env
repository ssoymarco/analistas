# ─────────────────────────────────────────────────────────────
# Analistas — Environment Variables
# Copy this file to .env.local for local overrides.
# NEVER commit .env.local (it may contain real secrets).
# ─────────────────────────────────────────────────────────────

# Google Sign-In — Android Client ID
# Needed to enable Google Sign-In on Android devices.
#
# Steps to get this:
#   1. Firebase Console → Project Settings → Add Android app
#      Package name: app.analistas
#      Download google-services.json → place at project root
#   2. Google Cloud Console → APIs & Services → Credentials
#      Create OAuth 2.0 Client ID → Android
#      Package name: app.analistas  |  SHA-1: (see below)
#   3. Paste the Client ID here (format: xxxxxxxx.apps.googleusercontent.com)
#
# SHA-1 for development (Expo Go):
#   Run: npx expo credentials:manager  OR  keytool -list -v -keystore ~/.android/debug.keystore
#
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=562270448336-l6465c4ietcle0b6kgevabe0hglsjbv6.apps.googleusercontent.com
