{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo (universal)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 8081
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ios"],
      "port": 8081
    },
    {
      "name": "Expo Android",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 8081
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["node_modules/.bin/expo", "start", "--web", "--port", "8081"],
      "port": 8081
    }
  ]
}
